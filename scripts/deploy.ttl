; deploy.ttl — Volley Coach デプロイマクロ
; Tera Term で実行すると SSH接続 → git pull → サービス再起動 を自動実行

host = '157.7.65.123'
port = '22'
username = 'aoki'
keyfile = 'C:\Users\shoji\.ssh\id_ed25519'

; SSH接続
cmd = 'ssh://'
strconcat cmd username
strconcat cmd '@'
strconcat cmd host
strconcat cmd ':'
strconcat cmd port
strconcat cmd ' /ssh /auth=publickey /user='
strconcat cmd username
strconcat cmd ' /keyfile='
strconcat cmd keyfile

connect cmd

; ログイン完了待ち
wait '$' 'aoki@' '#'

; デプロイ実行
sendln 'cd /apl_coach/app && git pull && sudo systemctl restart coach'

; sudo パスワード prompt が出た場合の対応
; パスワード不要（NOPASSWD設定済み）なら wait のみで通過する
wait '$' 'aoki@' '#' 'password'
if result = 4 then
    ; パスワード入力が必要な場合
    inputbox 'sudo パスワードを入力してください' 'Deploy'
    sendln inputstr
    wait '$' 'aoki@' '#'
endif

; 完了メッセージ
sendln 'echo "=== deploy done ==="'
wait '=== deploy done ==='

messagebox 'デプロイが完了しました' 'Deploy'
